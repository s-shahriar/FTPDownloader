{
  "expo": {
    "name": "FTPDownloader",
    "slug": "FTPDownloader",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f4f8"
    },
    "backgroundColor": "#f2f4f8",
    "primaryColor": "#3d7fff",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Allow FTPDownloader to save downloaded files to your photo library",
        "NSPhotoLibraryUsageDescription": "Allow FTPDownloader to access your photo library to save downloaded files"
      }
    },
    "android": {
      "package": "com.ftpdownloader.app",
      "versionCode": 1,
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#f2f4f8"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "49d8ec67-53bc-4d79-a325-4af01b8a6168"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3d7fff",
          "sounds": []
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow FTPDownloader to save downloaded files to your device",
          "savePhotosPermission": "Allow FTPDownloader to save downloaded files to your device",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-file-system",
        {
          "intentFilters": [
            {
              "action": "android.intent.action.VIEW",
              "data": [
                {
                  "scheme": "http",
                  "host": "*",
                  "pathPattern": ".*\\.mkv"
                },
                {
                  "scheme": "http",
                  "host": "*",
                  "pathPattern": ".*\\.mp4"
                }
              ]
            }
          ]
        }
      ],
      "expo-font"
    ]
  }
}
